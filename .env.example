# ============================================================
# ODYSSEY AI — Environment Variables Template
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# In production, all secrets live in Google Cloud Secret Manager.
# ============================================================

# App
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Google Maps Platform ─────────────────────────────────────
# Enable: Maps JS API, Places API (New), Directions, Routes, Distance Matrix
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Google AI / Gemini ───────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google Cloud / Vertex AI ─────────────────────────────────
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_CLOUD_PROJECT=

# ── Firebase ─────────────────────────────────────────────────
# Admin SDK (server-side only — never expose to browser)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Client SDK (safe to expose — next public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ── Database ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis ────────────────────────────────────────────────────
# Get from: https://upstash.com
REDIS_URL=

# ── Search ───────────────────────────────────────────────────
# Get from: https://dashboard.algolia.com
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# API auth fallback for local/dev only
ALLOW_ANON_AUTH=true
