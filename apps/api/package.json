{
  "name": "@odyssey/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run ../../tests/unit/services",
    "test:integration": "vitest run ../../tests/integration/routes",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@odyssey/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.47.10",
    "@upstash/redis": "^1.34.3",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "firebase-admin": "^13.0.2",
    "pino": "^9.6.0",
    "pg": "^8.13.1",
    "pgvector": "^0.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
